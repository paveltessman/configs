  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.other"
      ],
      "settings": {
        "foreground": "#d9ded7"
      }
    },
    {
      "name": "String escape / special",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#f592d6"
      }
    },
    {
      "name": "Number / Boolean / Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d9ded7"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c0afff"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "name": "Punctuation brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.section.block",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Type / Class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Built-in type / Interface",
      "scope": [
        "support.type",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#dddddd"
      }
    },
    {
      "name": "Variable — parameter",
      "scope": [
        "variable.parameter",
        "variable.other.parameter"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Variable — property / field",
      "scope": [
        "variable.other.property",
        "variable.other.member",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Constant / Enum member",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Constructor",
      "scope": [
        "entity.name.function.constructor",
        "meta.function-call.constructor",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#00dfce"
      }
    },
    {
      "name": "Decorator / Attribute",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#f592d6"
      }
    },
    {
      "name": "Label",
      "scope": [
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#00dfce"
      }
    },
    {
      "name": "Tag name (HTML / JSX)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#c0afff"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffe081"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "CSS value / unit",
      "scope": [
        "support.constant.property-value",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#fa9a6d"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#ffe081"
      }
    },
    {
      "name": "Markup heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#c0afff"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fa9a6d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f592d6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "Markup code block",
      "scope": [
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#d9ded7"
      }
    },
    {
      "name": "Markup list",
      "scope": [
        "markup.list punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#fa9a6d"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ea746c"
      }
    },
    {
      "name": "Invalid deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ffc0b9"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "TOML key",
      "scope": [
        "keyword.key.toml",
        "entity.name.tag.toml"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "Shell builtin / command",
      "scope": [
        "support.function.builtin.shell",
        "entity.name.command.shell"
      ],
      "settings": {
        "foreground": "#EAE4DD"
      }
    },
    {
      "name": "Shell variable",
      "scope": [
        "variable.other.normal.shell",
        "variable.other.special.shell"
      ],
      "settings": {
        "foreground": "#fa9a6d"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#47deb4"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ea746c"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#ffe081"
      }
    }
  ]
}
